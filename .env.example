############################################################
# Core runtime
############################################################
NODE_ENV=production
PORT=3000
IS_DOCKER=true
ALLOWED_ORIGINS=https://your-domain.com

############################################################
# Secrets & auth
############################################################
JWT_SECRET=replace_with_secure_random_value_at_least_32_chars
OPENAI_API_KEY=sk-your-openai-key
WEBHOOK_URL=

############################################################
# AI defaults (overridable per bot desde el dashboard)
############################################################
SYSTEM_PROMPT=Eres Neo, un asistente inteligente.
AI_MODEL=gpt-4o-mini

############################################################
# Database (PostgreSQL)
############################################################
POSTGRES_DB=huao
POSTGRES_USER=huao_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://huao_user:change_me@postgres:5432/huao?schema=public&connection_limit=5
PRISMA_LOG_LEVEL=info

############################################################
# Networking / TLS (Caddy)
############################################################
DOMAIN=your-domain.com
EMAIL=you@example.com

############################################################
# WhatsApp session tuning (opcional)
############################################################
MAX_PARALLEL_WA_CONNECT=3
SESSION_RESTORE_BATCH_SIZE=5
SESSION_RESTORE_DELAY_MS=2000
SESSION_START_BASE_DELAY_MS=500
SESSION_START_JITTER_MS=750
MESSAGE_BUFFER_WINDOW_MS=3500
MESSAGE_BUFFER_MAX=3
